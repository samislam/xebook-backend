{
  "compilerOptions": {
    "rootDir": "./",
    "types": ["jest", "node"],
    "paths": {
      "@/*": ["./src/*"],
      "@/auth/*": ["./src/modules/auth/*"],
      "@/balances/*": ["./src/modules/balances/*"],
      "@/counterparties/*": ["./src/modules/counterparties/*"],
      "@/debt-balances/*": ["./src/modules/debt-balances/*"],
      "@/held-balances/*": ["./src/modules/held-balances/*"],
      "@/institution-accounts/*": ["./src/modules/institution-accounts/*"],
      "@/inventory-lots/*": ["./src/modules/inventory-lots/*"],
      "@/institutions/*": ["./src/modules/institutions/*"],
      "@/order-settlements/*": ["./src/modules/order-settlements/*"],
      "@/orders/*": ["./src/modules/orders/*"],
      "@/rate-snapshots/*": ["./src/modules/rate-snapshots/*"],
      "@/sale-executions/*": ["./src/modules/sale-executions/*"],
      "@/transactions/*": ["./src/modules/transactions/*"],
      "@/users/*": ["./src/modules/users/*"],
      "@/common/dto/*": ["./src/common/dtos/*"],
      "@/common/dtos/*": ["./src/common/dtos/*"]
    },
    "strict": true,
    "sourceMap": true,
    "target": "ES2021",
    "incremental": false,
    "skipLibCheck": true,
    "module": "commonjs",
    "noImplicitAny": true,
    "removeComments": true,
    "esModuleInterop": true,
    "strictNullChecks": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "strictBindCallApply": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true,
    "strictPropertyInitialization": false,
    "forceConsistentCasingInFileNames": true,
    "noPropertyAccessFromIndexSignature": false
  },
  "include": ["./src/**/*.ts", "./tests/**/*.ts", "./scripts/**/*.ts"]
}
